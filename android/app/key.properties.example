# Copy this file to `key.properties` (in the same directory) and fill in
# your release keystore details. The real `key.properties` is git-ignored.
#
# Generate a keystore once with:
#   keytool -genkey -v -keystore noor-release.jks -keyalg RSA -keysize 2048 \
#           -validity 10000 -alias noor

storePassword=YOUR_STORE_PASSWORD
keyPassword=YOUR_KEY_PASSWORD
keyAlias=noor
storeFile=/absolute/path/to/noor-release.jks
